block header
    header.header
        .header__top
            .container
                .header__top-inner
                    .header__logo
                        if (indexPage)
                            .header-logo
                                img(src="/src/assets/logo.svg" alt="MEDINNOV" width="147" height="18")
                        else
                            a.header-logo(href="/" title="Главная")
                                img(src="/src/assets/logo.svg" alt="MEDINNOV" width="147" height="18")

                    .header__search
                        a.btn.header__catalog-btn(href="/catalog.html" title="Каталог")
                            +svgIcon('search-btn', "header__catalog-btn-icon d-block d-lg-none")
                            span.d-none.d-lg-block Каталог

                        include /components/header/header-search

                    .header__actions
                        .header__contacts
                            a.header__phone(href="tel:+79050868992" title="+7 (905) 086-89-92") +7 (905) 086-89-92

                        if !indexPage
                            a.header__action._user(href="#js-modal-auth" title="Кабинет")
                                svg(
                                    width="26"
                                    height="26"
                                    viewBox="0 0 26 26"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                )
                                    circle(
                                        cx="13"
                                        cy="13"
                                        r="11"
                                        fill="#6CB3EE"
                                    )
