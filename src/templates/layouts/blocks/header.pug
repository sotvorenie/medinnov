                                        fill="white"
                                    )
                        else
                            a.header__action._user(href="#js-modal-auth" title="Войти" data-fancybox)
                                svg(
                                    width="26"
                                    height="26"
                                    viewBox="0 0 26 26"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                )
                                    circle(
                                        cx="13"
                                        cy="13"
                                        r="11"
                                        fill="#6CB3EE"
                                    )
                                    path(
                                        d="M17.018 12.4466C17.4808 11.6875 17.7285 10.8138 17.7379 9.91146C17.7472 8.6224 17.2564 7.40017 16.3635 6.47396C15.466 5.54774 14.2787 5.03689 13.0165 5.02734C13.0072 5.02734 12.9978 5.02734 12.9885 5.02734C11.7216 5.02734 10.5343 5.52865 9.63676 6.44054C8.73456 7.3572 8.23438 8.57943 8.23438 9.88281C8.23438 10.7947 8.48213 11.6827 8.95427 12.4514C9.55729 13.4397 10.4642 14.151 11.5113 14.4996C11.5347 14.5043 11.5534 14.5139 11.5767 14.5187C11.8011 14.5903 12.0302 14.6428 12.2639 14.681C12.2732 14.681 12.2779 14.681 12.2873 14.6858C12.334 14.6905 12.3808 14.7001 12.4275 14.7049C12.4415 14.7049 12.4556 14.7096 12.4696 14.7096C12.5117 14.7144 12.5537 14.7192 12.5958 14.7192C12.6145 14.7192 12.6285 14.724 12.6472 14.724C12.6893 14.7287 12.7314 14.7287 12.7734 14.7287H12.8202C12.8763 14.7287 12.9324 14.7335 12.9885 14.7335C13.0446 14.7335 13.1007 14.7335 13.1568 14.7287H13.2035C13.2456 14.7287 13.2876 14.724 13.3297 14.724C13.3484 14.724 13.3624 14.7192 13.3811 14.7192C13.4232 14.7144 13.4653 14.7096 13.5027 14.7096C13.5167 14.7096 13.5307 14.7049 13.5447 14.7049C13.5915 14.7001 13.6382 14.6953 13.685 14.6858C13.6943 14.6858 13.699 14.6858 13.7084 14.681C13.9421 14.6428 14.1711 14.5903 14.3955 14.5187C14.4189 14.5139 14.4376 14.5043 14.461 14.4996C15.5081 14.1463 16.415 13.4349 17.018 12.4466Z"
                                        fill="white"
