        label(class=`textfield ${className} ${required ? 'textfield_required' : ''}`)
            span.textfield__name= name 
            input.textfield__input(type='tel' placeholder=placeholder required=required ? true : false  data-maska="#####" data-validate-input=`${required}`)

mixin textarea(name, placeholder, rows = 4, className = '', required = false)
    .form-row
        label(class=`textarea ${className} ${required ? 'textarea_required' : ''}`)
            span.textarea__name= name 
            textarea.textarea__input(placeholder=placeholder, rows=rows data-validate-input=`${required}`)

mixin formAgreement(className = '')
    p(class=`form-agreement ${className}`) Нажимая на кнопку, 
        a.form-agreement__link(href="/privacy.html") вы соглашаетесь с условиями обработки данных и политикой конфиденциальности

mixin radioButton(labelText = 'radio button', name = 'radio', className = '', checked = false, disabled = false)
    label(class=`radio-btn ${className || ''}`)
        input.radio-btn__input(type="radio" checked=checked disabled=disabled name=name)
        div.radio-btn__box= labelText

mixin radioColor(labelColor = '#f00', name = 'radio', className = '', checked = false, disabled = false)
    label(class=`radio-color ${className || ''}`)
        input.radio-color__input(type="radio" checked=checked disabled=disabled name=name)
        div.radio-color__box
            span.radio-color__box-color(style='background-color:' + labelColor)

mixin file(name, required = false, className = '')
    .form-row
        label(class=`input-file ${className} ${required ? 'input-file_required' : ''}` data-input-file)
            span.input-file__value(data-input-file-value)
            span.input-file__btn
                +svgIcon('file')
                span= name 
            input.input-file__input(type="file" required=required ? true : false data-validate-input=`${required}`)

