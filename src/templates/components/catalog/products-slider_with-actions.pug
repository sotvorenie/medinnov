.products-slider-wrapper_with-actions
    .products-slider-wrapper
        .products-slider.js-products-slider
            .products-slider__wrapper
                - for (let i = 0; i < 8; i++)
                    .products-slider__item
                        include /components/catalog/product-item

    .slider-action._prev.products-slider-action.js-products-slider-prev
        +svgIcon('arrow-left')
    .slider-action._next.products-slider-action.js-products-slider-next
        <svg class="icon" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 18L16 13L11 8V18Z" fill="currentColor"/>
        </svg>