        .filter__content(data-filter)
            .filter__content-title.h1 
                button.filter__content-back(data-hide-filter)
                    +svgIcon('arrow-left')
                span Фильтры
            
            .filter__sections
                .filter__sections-list
                    - for (let i = 0; i < 8; i++)
                        .filter-sections-item
                            .filter-sections-item__head(class=(i === 0) && '_active' data-accordeon-toggle)
                                | Стоматологическое оборудование
                                +svgIcon('arrow-down')

                            div(class=(i === 0) && '_active' data-accordeon-content)
                                .filter-sections-item__list
                                    - for (let j = 0; j < 15; j++)
                                        .filter-sections-item__list-item(data-more-item=(j > 6 ? 'true' : 'false'))
                                            +checkbox('Стоматологические установки', '', (i === 0) && (j === 0))

                                    
                                    button.btn.btn_bordered.btn_sm(type="button" data-show-more)
                                        span(data-text-show) Показать все
                                        span(data-text-hide) Скрыть

            .filter__item
                .filter__item-title Бренд
                .filter__item-cont
                    .checkbox-list
                        - for (let i = 0; i < 6; i++)
                            +checkbox('Бренд ' + i, '', (i === 0))

            .filter__item
                .filter__item-title Радиобатоны
                .filter__item-cont
                    .checkbox-list
                        - for (let i = 0; i < 6; i++)
                            +radio('Радиобатон ' + i, '', (i === 0), 'radio-test')

            .filter__item
                .filter__item-title Тип подачи инструментов
                .filter__item-cont
                    .checkbox-list
                        each i in ['Нижняя', 'Верхняя', 'Верхняя']
                            +checkbox(i)

            .filter__item
                .filter__item-title Обивка
                .filter__item-cont
                    .checkbox-list
                        each i in ['Шовная', 'Верхняя', 'Бесшовная']
                            +checkbox(i)

            .filter__item
                .filter__item-title 
                    | Количество инструментов 
                    |
                    span.filter__item-title-comment (блок&nbsp;врача)
                .filter__item-cont
                    .checkbox-list
                        each i in ['5', '5/6', '6']
                            +checkbox(i)

            .filter__item
                .filter__item-title Тип гидроблока
                .filter__item-cont
                    .checkbox-list
                        each i in ['Вакуумный', 'Влажный', 'Электорный / Вакуумный']
                            +checkbox(i)

            .filter__item
                .filter__item-title Диапазон цен
                .filter__item-cont
                    include /components/catalog/range-slider

            .filter__item
                .filter__item-title 
                    +switch('Товары со скидкой')

            .filter__actions
                button.btn.btn_bordered(type="button" data-form-reset) Сбросить
                button.btn.d-lg-none(type="button" data-hide-filter) Применить