        .filter__content(data-filter)
            .filter__content-title.h1 
                button.filter__content-back(data-hide-filter)
                    +svgIcon('arrow-left')
                span Фильтры
            
            .filter__item
                .filter__item-title Бренд
                .filter__item-cont
                    .checkbox-list
                        - for (let i = 0; i < 6; i++)
                            +checkbox('Бренд ' + i, '', (i === 0))


            .filter__item
                .filter__item-title Диапазон цен
                .filter__item-cont
                    include /components/catalog/range-slider

            .filter__item
                .filter__item-title
                    +checkbox('Товары со скидкой')

            .filter__actions
                button.btn.btn_bordered(type="button" data-form-reset) Сбросить
                button.btn(type="button" data-hide-filter) Применить