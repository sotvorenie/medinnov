                        | Эксклюзив

                    .product-top__chip.product-top__chip_discount Скидка 15%
                .product-slider__main-enternal
                    .product-main-slider.js-product-main-slider
                        .product-main-slider__wrapper
                            - for (let i = 0; i < 8; i++)
                                .product-main-slider__item
                                    a.product-main-slider__link(href="/upload/detail/" + i % 4 + ".png" title data-fancybox="product-images")
                                        img.product-main-slider__img(src="/src/assets/upload/detail/" + i % 4 + ".png" alt)

            .product-slider__thumbs
                .product-slider__thumbs-enternal
                    .product-thumbs-slider.js-product-thumbs-slider
                        .product-thumbs-slider__wrapper
                            - for (let i = 0; i < 8; i++)
                                .product-thumbs-slider__item
                                    .product-thumbs-slider__link(data-thumb-slider)
                                        img.product-thumbs-slider__img(src="/src/assets/upload/detail/" + i % 4 + ".png" alt)

    .product-top__content 
        .product-top__content-enternal
            .product-top__content-main
                .product-top__warranty
                    img.product-top__warranty-icon(src="/src/assets/warranty.svg", alt="")
                    | Гарантия 3 года

                .product-settings
                    .product-settings__title 
                        span Регистрационное удостоверение
                    .product-settings__value ФСЗ 2008/03029
                .product-settings
                    .product-settings__title 
                        span Производитель
                    .product-settings__value Foshan Roson Medical Instruments Co
                .product-settings
                    .product-settings__title
                        span Страна
                    .product-settings__value Китай

                .product-top__desc 
                    div(data-show-content-block) Стоматологическая установка Foshan Roson KLT-6210 N1 Upper, благодаря своим функциональным возможностям, является оптимальным решением для профессионального и приятного лечения пациентов.

                .mt-3
                    .h5 Тип подачи инструментов
                    .radio-list
                        +radioButton('Нижняя', 'radio-1', '', true)
                        +radioButton('Верхняя', 'radio-1', '', false)

                .mt-3
                    .h5 Вариант обивки
                    .radio-list
                        +radioButton('Бесшовная', 'radio-2', '', true)
                        +radioButton('Шовная', 'radio-2', '', false)
                        +radioButton('Другая', 'radio-2', '', false, true)

                .mt-3
                    .h5 Цвет
                    .radio-list
                        div(data-more-item="false")
                            +radioColor('#69A2AC', 'radio-3', '', true)
                        div(data-more-item="false")
                            +radioColor('#f00', 'radio-3', '')
                        div(data-more-item="false")
                            +radioColor('#0f0', 'radio-3', '')
                        div(data-more-item="false")
                            +radioColor('#00f', 'radio-3', '')
                        div(data-more-item="true")
                            +radioColor('#ff0', 'radio-3', '')
                        div(data-more-item="true")
                            +radioColor('#fff', 'radio-3', '')
                        div(data-more-item="true")
                            +radioColor('#000', 'radio-3', '', false, true)

                        div.radio-list__more(data-show-more)
                            span(data-text-show) Еще
                            span(data-text-hide) Скрыть

            .product-top__content-sidebar
                .product-top__actions
                    .d-flex.align-items-center.justify-content-between
                        .product-top__price 4 526 $
                        .product-top__availability
                            if (notAvailable)
                                span.text-red Нет в наличии
                            else 
                                span.text-green В наличии

                    .product-top__price-convert Цена в рублях: 450 000 ₽
                    .product-top__price-old 5 026 $


                    if (notAvailable)
                        .product-top__action
                            button.btn.product-item__btn.d-flex(data-fancybox data-src="#js-modal-notify")
                                .product-item__btn-icon
                                    +svgIcon('bell')
                                .product-item__btn-text Уведомить
                    else 
                        .product-top__action
                            button.btn.product-item__btn(data-toggle-action data-add-to-basket)
                                .product-item__btn-icon.btn__icon
                                    +svgIcon('cart')
                                .product-item__btn-text.btn__text В корзину

                            a.btn.btn_bordered.product-item__btn(href="/basket.html")
                                .product-item__btn-icon.btn__icon
                                    +svgIcon('cart')
                                .product-item__btn-text.btn__text Перейти в корзину

                        .product-top__action
                            btn.btn.btn_bordered Оформить в рассрочку

                .product-top__attention.mt-2
                    .product-top__attention-top
                        img.icon(src="/src/assets/attention.svg", alt="")
                        div Внимание!
                    .product-top__attention-cont
                        | Уточняйте спецификацию, комплектацию, характеристики, внешний вид, наличие на складе и цену товара у менеджеров нашей компании. Указанные цены на сайте не являются публичной офертой.
                        br
                        span.text-red *Цена в рублях рассчитана от 05.12.2024
